# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.eggs/
.installed.cfg

# Virtual envs
.venv/
venv/
env/

# Tooling caches
.ruff_cache/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# ---- Build / packaging artifacts ----
# PyInstaller writes here; these are produced in CI, never committed.
/build/
/dist/
*.manifest
# NOTE: do NOT add a blanket *.spec ignore — packaging/cherrybomb.spec is tracked on purpose.

# Locally-fetched browser binaries (Playwright/Patchright) and runtime caches
.cache/
playwright-browsers/

# ---- Secrets / runtime state (never commit) ----
# Scraper sessions, cookies, proxy lists, burner-account creds.
*.session
*.cookies
secrets/
.env
.env.*
proxies.txt

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
